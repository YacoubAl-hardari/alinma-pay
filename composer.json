{
    "name": "alinmapay/laravel-alinmapay",
    "description": "Laravel package for Alinma Pay Payment Gateway integration",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "AlinmaPay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AlinmaPay\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "AlinmaPay\\AlinmaPayServiceProvider"
            ],
            "aliases": {
                "AlinmaPay": "AlinmaPay\\Facades\\AlinmaPay"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}